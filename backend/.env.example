APP_NAME="Ads Dashboard"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ads_dashboard
DB_USERNAME=ads
DB_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="dashboard@kgmedia.io"
MAIL_FROM_NAME="${APP_NAME}"

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_URL=http://localhost:5173,http://localhost:4173

# Generate with: php artisan jwt:secret
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Live monitoring
MONITOR_REGION=default
MONITOR_TIMEOUT=15

# External integrations (do NOT commit real values)
# Google Chrome UX Report (real field Web Vitals). Free key: https://developer.chrome.com/docs/crux/api
CRUX_API_KEY=
# Google Ad Manager (revenue/impressions) — OAuth2 service account
GAM_NETWORK_CODE=
GAM_SERVICE_ACCOUNT_JSON=
# Optional: map GAM (parent) ad unit name -> domain url/uuid for domain resolution
# GAM_DOMAIN_MAP={"Kompas TV":"https://www.kompas.tv","Sonora":"https://www.sonora.id"}
GAM_DOMAIN_MAP=
GA4_PROPERTY_ID=

# Prebid analytics ingestion (browser push from publisher sites)
PREBID_INGEST_KEY=
# Comma-separated publisher origins allowed to POST beacons (CORS), e.g.
# PREBID_INGEST_ORIGINS=https://www.kompas.tv,https://www.parapuan.co,https://www.sonora.id
PREBID_INGEST_ORIGINS=

# Security Site Inspector — rate limiting (optional Upstash Redis)
SECURITY_SCAN_PER_MINUTE=3
SECURITY_SCAN_PER_HOUR=30
# Set to "upstash" to rate-limit via Upstash Redis (else default cache store)
SECURITY_SCAN_RATELIMIT_STORE=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=
UPSTASH_REDIS_SCHEME=tls
